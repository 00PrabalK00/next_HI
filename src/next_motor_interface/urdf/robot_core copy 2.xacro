<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="my_robot_core">

  <!-- inertial helper macros (needed by your lidar.xacro) -->
  <xacro:include filename="inertial_macros.xacro"/>

  <!-- PROPERTIES (match your ROS1 dimensions) -->
  <xacro:property name="chassis_length" value="0.80"/>
  <xacro:property name="chassis_width"  value="0.58"/>
  <xacro:property name="chassis_height" value="0.20"/>
  <xacro:property name="chassis_mass"   value="1.0"/>

  <xacro:property name="wheel_radius"    value="0.10"/>
  <xacro:property name="wheel_thickness" value="0.04"/>
  <xacro:property name="wheel_mass"      value="0.05"/>
  <xacro:property name="wheel_offset_y"  value="0.29"/>

  <!-- MATERIALS -->
  <material name="blue"><color rgba="0.2 0.2 1 1"/></material>
  <material name="orange"><color rgba="1 0.3 0.1 1"/></material>


  <link name="base_footprint"/>

  <link name="base_link"/>
  <!-- base_footprint -> base_link (so odom->base_footprint from controller is valid) -->
  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <!-- If you want base_footprint on ground and base_link at axle height -->
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <joint name="chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="chassis"/>
    <!-- keep your ROS1 offset -->
    <origin xyz="0 0 -0.01" rpy="0 0 0"/>
  </joint>

  <link name="chassis">
    <visual>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="orange"/>
    </visual>

    <collision>
      <origin xyz="0.15 0 0.055" rpy="0 0 0"/>
      <geometry>
        <box size="0.30 0.16 0.11"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="${chassis_mass}"/>
      <origin xyz="0.15 0 0.055" rpy="0 0 0"/>
      <inertia ixx="0.0011" ixy="0" ixz="0" iyy="0.0011" iyz="0" izz="0.0011"/>
    </inertial>
  </link>

  <!-- =========================
       WHEELS
       ========================= -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel"/>
    <origin xyz="0 ${wheel_offset_y} 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_thickness}"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_thickness}"/></geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel"/>
    <origin xyz="0 -${wheel_offset_y} 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_thickness}"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_thickness}"/></geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

</robot>
