# Motor feedback message for Kinco drives
# Published at controller update rate (typically 100 Hz)

std_msgs/Header header

# Right wheel (Motor ID 1)
float64 right_wheel_position_rad
float64 right_wheel_velocity_rad_s
float64 right_wheel_command_rad_s
uint16 right_wheel_statusword

# Left wheel (Motor ID 2)
float64 left_wheel_position_rad
float64 left_wheel_velocity_rad_s
float64 left_wheel_command_rad_s
uint16 left_wheel_statusword
